title: Lost at Sea
permalink: /404.html
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | crustaceans.sh</title>
  <style>
    :root {
      --sand: #f6efe2;
      --cream: #fffaf1;
      --foam: #f5fbff;
      --sea: #5d8fa3;
      --deep-sea: #28576b;
      --coral: #d87959;
      --ink: #26343c;
      --coffee: #6d4a38;
      --sun: #f4c96b;
      --shadow: rgba(37, 53, 66, 0.16);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --sand: #1a1f24;
        --cream: #232a30;
        --foam: #2d353d;
        --sea: #5d8fa3;
        --deep-sea: #8ab4c7;
        --coral: #d87959;
        --ink: #e8ebe8;
        --coffee: #b8a595;
        --sun: #f4c96b;
        --shadow: rgba(0, 0, 0, 0.4);
      }
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(244, 201, 107, 0.12), transparent 24%),
        radial-gradient(circle at top right, rgba(93, 143, 163, 0.1), transparent 30%),
        linear-gradient(180deg, var(--sand) 0%, #2a3038 42%, #1f242a 100%);
    }

    .frame {
      max-width: 600px;
      margin: 0 auto;
      padding: 1.2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.4));
      border-radius: 28px;
      box-shadow: 0 24px 64px var(--shadow);
    }

    .sheet {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--cream), var(--foam));
      border: 2px solid rgba(109, 74, 56, 0.2);
      border-radius: 24px;
      padding: 3rem 2rem;
      text-align: center;
      box-shadow: inset 0 0 0 10px rgba(255,255,255,0.08);
    }

    h1 {
      font-size: 6rem;
      margin: 0;
      color: var(--sea);
      line-height: 1;
    }

    h2 {
      color: var(--deep-sea);
      margin-top: 0.5rem;
    }

    p {
      line-height: 1.75;
      color: var(--ink);
    }

    a {
      color: var(--sea);
    }

    .crab {
      font-size: 4rem;
      margin: 1rem 0;
    }
  </style>
</head>
<body>
  <div class="frame">
    <article class="sheet">
      <div class="crab">🦀</div>
      <h1>404</h1>
      <h2>Lost at Sea</h2>
      <p>This page drifted away with the tide. No worries — the shore has more boardwalks.</p>
      <p><a href="/">← Back to the postcard rack</a></p>
    </article>
  </div>
</body>
</html>
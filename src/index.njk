  <style>
    :root {
      --sand: #f6efe2;
      --cream: #fffaf1;
      --foam: #f5fbff;
      --sea: #5d8fa3;
      --deep-sea: #28576b;
      --coral: #d87959;
      --stamp: #d6c3a4;
      --ink: #26343c;
      --coffee: #6d4a38;
      --coffee-foam: #c6a98b;
      --sun: #f4c96b;
      --shadow: rgba(37, 53, 66, 0.18);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(244, 201, 107, 0.22), transparent 24%),
        radial-gradient(circle at top right, rgba(93, 143, 163, 0.16), transparent 30%),
        linear-gradient(180deg, #f7efe3 0%, #f4ead8 42%, #efe2cf 100%);
    }

    .frame {
      max-width: 1040px;
      margin: 0 auto;
      padding: 1.2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.4));
      border-radius: 28px;
      box-shadow: 0 24px 64px var(--shadow);
    }

    .postcard {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--cream), #fff7ec 52%, #fff2df 100%);
      border: 2px solid #ead8b8;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: inset 0 0 0 10px rgba(255,255,255,0.38);
    }

    .postcard::before,
    .postcard::after {
      content: "";
      position: absolute;
      inset: 16px;
      border: 1px dashed rgba(109, 74, 56, 0.18);
      pointer-events: none;
      border-radius: 18px;
    }

    .postcard::after {
      inset: auto 24px 24px auto;
      width: 112px;
      height: 136px;
      border: 2px dashed rgba(40, 87, 107, 0.24);
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(93, 143, 163, 0.1), rgba(216, 121, 89, 0.08)),
        repeating-linear-gradient(180deg, transparent 0 10px, rgba(40, 87, 107, 0.08) 10px 12px);
      box-shadow: 0 8px 18px rgba(40, 87, 107, 0.09);
    }

    .coffee-ring,
    .compass,
    .crab-mark {
      position: absolute;
      pointer-events: none;
      opacity: 0.18;
    }

    .coffee-ring {
      top: 1.1rem;
      right: 8.5rem;
      width: 170px;
      height: 170px;
      border: 5px solid rgba(109, 74, 56, 0.2);
      border-radius: 50%;
      transform: rotate(-10deg);
      box-shadow: inset 0 0 0 12px rgba(109, 74, 56, 0.05);
    }

    .compass {
      left: -1.2rem;
      bottom: 6rem;
      width: 96px;
      height: 96px;
    }

    .crab-mark {
      right: 2.2rem;
      top: 18rem;
      width: 86px;
      height: 86px;
    }

    header {
      position: relative;
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 1.5rem;
      align-items: start;
      margin-bottom: 1.4rem;
      padding-bottom: 1.4rem;
      border-bottom: 1px solid rgba(109, 74, 56, 0.18);
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 0.55rem;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      background: rgba(244, 201, 107, 0.25);
      color: var(--coffee);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-weight: 700;
    }

    header h1 {
      margin: 0;
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      color: var(--deep-sea);
    }

    .lede {
      margin: 0.7rem 0 0;
      max-width: 34rem;
      font-size: 1.06rem;
      line-height: 1.7;
      color: #415058;
    }

    .stamp-stack {
      display: grid;
      gap: 0.85rem;
      justify-items: end;
    }

    .stamp-card,
    .coffee-card {
      width: min(100%, 250px);
      padding: 1rem;
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,248,238,0.88));
      border: 1px solid rgba(216, 121, 89, 0.22);
      box-shadow: 0 10px 24px rgba(0,0,0,0.06);
      transform: rotate(1.5deg);
    }

    .coffee-card {
      transform: rotate(-2deg);
      border-color: rgba(109, 74, 56, 0.18);
    }

    .stamp-title {
      margin: 0 0 0.4rem;
      font: 700 0.78rem/1.2 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--coral);
    }

    .stamp-note {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.5;
      color: #4a5d66;
    }

    .hero-grid,
    .rack-grid,
    .harbor-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1rem;
      margin: 1.4rem 0 0;
    }

    .panel,
    .rack,
    .steps,
    .harbor-card {
      background: rgba(255,255,255,0.56);
      border: 1px solid rgba(40, 87, 107, 0.12);
      border-radius: 18px;
      padding: 1.15rem 1.15rem 1rem;
      box-shadow: 0 10px 24px rgba(40, 87, 107, 0.05);
    }

    .panel h2,
    .steps h2,
    .rack h2,
    .harbor-card h2,
    .section-title {
      margin: 0 0 0.7rem;
      font-size: 1.25rem;
      line-height: 1.2;
      color: var(--deep-sea);
    }

    .panel p,
    .steps p,
    .rack p,
    .harbor-card p,
    li {
      font-size: 1rem;
      line-height: 1.7;
    }

    .hero-copy { grid-column: span 8; }
    .hero-sidebar { grid-column: span 4; }

    .crew-list,
    .link-list,
    .harbor-meta {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.75rem;
    }

    .crew-list li,
    .link-list li,
    .harbor-meta li {
      padding: 0.85rem 0.95rem;
      border-radius: 14px;
      background: rgba(245, 251, 255, 0.72);
      border: 1px solid rgba(93, 143, 163, 0.16);
    }

    .crew-list strong,
    .harbor-card strong {
      display: inline-block;
      margin-bottom: 0.2rem;
      color: var(--coffee);
    }

    .section-band {
      margin-top: 1.5rem;
      padding: 1.15rem 1.2rem;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(244, 201, 107, 0.16), rgba(93, 143, 163, 0.08));
      border: 1px solid rgba(216, 121, 89, 0.14);
    }

    .section-band p {
      margin: 0;
      font-size: 1.03rem;
      line-height: 1.75;
    }

    .steps ol {
      margin: 0;
      padding-left: 1.35rem;
    }

    .steps li + li { margin-top: 0.7rem; }

    .rack-grid .rack,
    .harbor-grid .harbor-card { grid-column: span 4; }

    .harbor-card {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(245,251,255,0.62));
    }

    .harbor-card::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 64px;
      height: 64px;
      background: linear-gradient(135deg, rgba(244, 201, 107, 0.22), rgba(216, 121, 89, 0.12));
      border-bottom-left-radius: 18px;
    }

    a {
      color: var(--deep-sea);
      text-decoration-thickness: 1.5px;
      text-underline-offset: 0.14em;
    }

    a:hover { color: var(--coral); }

    .mini-label {
      display: inline-block;
      margin-bottom: 0.55rem;
      color: var(--coffee);
      font: 700 0.72rem/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.14em;
    }

    footer {
      margin-top: 1.8rem;
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      color: #69777f;
      font-size: 0.92rem;
    }

    .stamp {
      border: 2px dashed rgba(93, 143, 163, 0.45);
      padding: 0.35rem 0.75rem;
      border-radius: 10px;
      background: rgba(245, 251, 255, 0.76);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font: 700 0.72rem/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--deep-sea);
    }

    @media (max-width: 860px) {
      header,
      .hero-grid,
      .rack-grid,
      .harbor-grid { grid-template-columns: 1fr; }
      .hero-copy,
      .hero-sidebar,
      .rack-grid .rack,
      .harbor-grid .harbor-card { grid-column: auto; }
      .stamp-stack { justify-items: start; }
      .postcard { padding: 1.35rem; }
      .postcard::after,
      .coffee-ring,
      .compass,
      .crab-mark { opacity: 0.28; }
    }
  </style>
</head>
<body>
  <div class="frame">
    <div class="postcard">

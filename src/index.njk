              </defs>

              <rect width="960" height="430" fill="url(#skyWash)" />
              <circle cx="810" cy="88" r="44" fill="#f7cb57" opacity="0.98" />
              <circle cx="810" cy="88" r="60" fill="none" stroke="rgba(247,203,87,0.25)" stroke-width="8" />

              <g opacity="0.7" stroke="#355f70" stroke-width="4" fill="none" stroke-linecap="round">

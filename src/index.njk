permalink: /index.html
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | crustaceans.sh</title>
  <style>
    :root {
      --sand: #f6efe2;
      --cream: #fffaf1;
      --foam: #f5fbff;
      --sea: #5d8fa3;
      --deep-sea: #28576b;
      --coral: #d87959;
      --ink: #26343c;
      --coffee: #6d4a38;
      --sun: #f4c96b;
      --shadow: rgba(37, 53, 66, 0.16);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(244, 201, 107, 0.22), transparent 24%),
        radial-gradient(circle at top right, rgba(93, 143, 163, 0.16), transparent 30%),
        linear-gradient(180deg, #f7efe3 0%, #f4ead8 42%, #efe2cf 100%);
    }

    .frame {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.4));
      border-radius: 28px;
      box-shadow: 0 24px 64px var(--shadow);
    }

    .sheet {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--cream), #fff5e8);
      border: 2px solid #ead8b8;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: inset 0 0 0 10px rgba(255,255,255,0.34);
    }

    .sheet::before {
      content: "";
      position: absolute;
      inset: 18px;
      border: 1px dashed rgba(109, 74, 56, 0.18);
      border-radius: 18px;
      pointer-events: none;
    }

    .coffee-ring {
      position: absolute;
      right: 2.8rem;
      top: 1.2rem;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      border: 6px solid rgba(109, 74, 56, 0.22);
      box-shadow: inset 0 0 0 12px rgba(109, 74, 56, 0.05);
      transform: rotate(-10deg);
      opacity: 0.55;
      mix-blend-mode: multiply;
      pointer-events: none;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .site-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 0 0 1.2rem;
    }

    .site-nav a {
      text-decoration: none;
      padding: 0.42rem 0.78rem;
      border-radius: 999px;
      background: rgba(93, 143, 163, 0.10);
      border: 1px solid rgba(40, 87, 107, 0.12);
      font: 600 0.92rem/1.1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--deep-sea);
    }

    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1rem;
      align-items: start;
      padding-bottom: 1.2rem;
      margin-bottom: 1.25rem;
      border-bottom: 1px solid rgba(109, 74, 56, 0.18);
    }

    .eyebrow,
    .mini {
      display: inline-block;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font: 700 0.72rem/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--coffee);
      background: rgba(244, 201, 107, 0.22);
      padding: 0.3rem 0.65rem;
      border-radius: 999px;
    }

    h1, h2, h3 { color: var(--deep-sea); }

    h1 {
      margin: 0.3rem 0 0;
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      line-height: 0.94;
      letter-spacing: -0.03em;
    }

    .lede,
    p,
    li {
      line-height: 1.75;
    }

    .note-card {
      background: rgba(255,255,255,0.76);
      border: 1px solid rgba(216, 121, 89, 0.18);
      border-radius: 18px;
      padding: 1rem;
      box-shadow: 0 10px 24px rgba(0,0,0,0.05);
      transform: rotate(-1.5deg);
    }

    .summary-band {
      margin: 1.1rem 0 0;
      padding: 1rem 1.1rem;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(244, 201, 107, 0.16), rgba(93, 143, 163, 0.08));
      border: 1px solid rgba(216, 121, 89, 0.12);
    }

    .postcard-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.2rem;
      margin-top: 1.5rem;
    }

    .postcard-card {
      grid-column: span 6;
      perspective: 1200px;
      min-height: 350px;
    }

    .postcard-flip {
      position: relative;
      width: 100%;
      min-height: 350px;
      transform-style: preserve-3d;
      transition: transform 0.75s ease;
    }

    .postcard-card:hover .postcard-flip,
    .postcard-card:focus-within .postcard-flip {
      transform: rotateY(180deg);
    }

    .postcard-face {
      position: absolute;
      inset: 0;
      border-radius: 22px;
      overflow: hidden;
      backface-visibility: hidden;
      border: 2px solid #ead8b8;
      box-shadow: 0 18px 36px rgba(37, 53, 66, 0.10);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .postcard-front {
      padding: 1.15rem 1.15rem 1.05rem;
      color: white;
      position: relative;
    }

    .postcard-front::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(0,0,0,0.42));
      z-index: 0;
    }

    .postcard-front::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 18% 18%, rgba(255,255,255,0.24), transparent 18%),
        radial-gradient(circle at 82% 24%, rgba(255,255,255,0.18), transparent 22%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(0,0,0,0.10));
      mix-blend-mode: screen;
      opacity: 0.45;
      z-index: 0;
    }

    .postcard-front > * {
      position: relative;
      z-index: 2;
    }

    .postcard-back {
      background: linear-gradient(180deg, #fffdf8, #fff4e5);
      padding: 1.15rem 1.15rem 1.05rem;
      transform: rotateY(180deg);
      color: var(--ink);
      justify-content: space-between;
    }

    .postcard-back .rule {
      border-top: 1px dashed rgba(109, 74, 56, 0.24);
      margin: 0.9rem 0;
    }

    .postcard-back p {
      margin: 0.2rem 0 0;
    }

    .postcard-back a {
      align-self: flex-start;
      text-decoration: none;
      padding: 0.5rem 0.8rem;
      border-radius: 999px;
      background: rgba(93, 143, 163, 0.10);
      border: 1px solid rgba(40, 87, 107, 0.12);
      color: var(--deep-sea);
      font: 600 0.92rem/1.1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .front-which { background: linear-gradient(135deg, #6ba9bd, #3c7389 50%, #274455); }
    .front-routes { background: linear-gradient(135deg, #efbf77, #d28a40 50%, #92522a); }
    .front-tuning { background: linear-gradient(135deg, #d78872, #b15d51 50%, #743934); }
    .front-community { background: linear-gradient(135deg, #8ab79b, #5e9274 50%, #345945); }

    .front-copy {
      position: relative;
      z-index: 2;
    }

    .front-illustration {
      position: relative;
      z-index: 2;
      margin-top: 1rem;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.08);
      min-height: 150px;
      display: flex;
      align-items: flex-end;
    }

    .front-art {
      width: 100%;
      height: auto;
      opacity: 0.62;
      pointer-events: none;
      filter: blur(0.4px) saturate(0.86);
      transform: scale(1.02);
      display: block;
    }

    .front-title {
      margin: 0.4rem 0 0;
      font-size: clamp(1.5rem, 3vw, 2rem);
      line-height: 1.05;
    }

    .front-note {
      margin: 0.45rem 0 0;
      max-width: 22rem;
    }

    .rack-footer {
      margin-top: 1.6rem;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      color: #6b777e;
      font-size: 0.94rem;
    }

    .stamp {
      border: 2px dashed rgba(93, 143, 163, 0.45);
      padding: 0.35rem 0.75rem;
      border-radius: 10px;
      background: rgba(245, 251, 255, 0.76);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font: 700 0.72rem/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--deep-sea);
    }

    a { color: var(--deep-sea); text-underline-offset: 0.14em; }
    a:hover { color: var(--coral); }

    @media (max-width: 900px) {
      .hero,
      .postcard-grid {
        grid-template-columns: 1fr;
      }

      .postcard-card {
        grid-column: auto;
      }

      .sheet {
        padding: 1.3rem;
      }

      .coffee-ring {
        width: 120px;
        height: 120px;
        right: 1rem;
        opacity: 0.35;
      }
    }
  </style>
</head>
<body>
  <div class="frame">
    <article class="sheet">
      <div class="coffee-ring"></div>
      <div class="content">
        <nav class="site-nav" aria-label="Site navigation">
          <a href="/">Postcard rack</a>
          <a href="/which-claw/">Which Claw?</a>

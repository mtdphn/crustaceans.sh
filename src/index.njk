      --ink: #26343c;
      --coffee: #6d4a38;
      --coffee-foam: #c6a98b;
      --sun: #f4c96b;
      --shadow: rgba(37, 53, 66, 0.18);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(244, 201, 107, 0.22), transparent 24%),
        radial-gradient(circle at top right, rgba(93, 143, 163, 0.16), transparent 30%),
        linear-gradient(180deg, #f7efe3 0%, #f4ead8 42%, #efe2cf 100%);
    }

    .frame {
      max-width: 1040px;
      margin: 0 auto;
      padding: 1.2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.4));
      border-radius: 28px;
      box-shadow: 0 24px 64px var(--shadow);
    }

    .postcard {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--cream), #fff7ec 52%, #fff2df 100%);
      border: 2px solid #ead8b8;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: inset 0 0 0 10px rgba(255,255,255,0.38);
    }

    .postcard::before,
    .postcard::after {
      content: "";
      position: absolute;
      inset: 16px;
      border: 1px dashed rgba(109, 74, 56, 0.18);
      pointer-events: none;
      border-radius: 18px;
    }

    .postcard::after {
      inset: auto 24px 24px auto;
      width: 112px;
      height: 136px;
      border: 2px dashed rgba(40, 87, 107, 0.3);
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(93, 143, 163, 0.16), rgba(216, 121, 89, 0.12)),
        repeating-linear-gradient(180deg, transparent 0 10px, rgba(40, 87, 107, 0.12) 10px 12px);
      box-shadow: 0 8px 18px rgba(40, 87, 107, 0.12);
      z-index: 0;
    }

    .coffee-ring,
    .compass,
    .crab-mark {
      position: absolute;
      pointer-events: none;
      z-index: 0;
    }

    .coffee-ring {
      top: 1.4rem;
      right: 7rem;
      width: 188px;
      height: 188px;
      border: 6px solid rgba(109, 74, 56, 0.28);
      border-radius: 50%;
      transform: rotate(-10deg);
      box-shadow:
        inset 0 0 0 12px rgba(109, 74, 56, 0.07),
        0 0 0 2px rgba(109, 74, 56, 0.06);
      opacity: 0.55;
      mix-blend-mode: multiply;
    }

    .compass {
      left: 1rem;
      bottom: 4.5rem;
      width: 128px;
      height: 128px;
      opacity: 0.72;
      filter: drop-shadow(0 6px 8px rgba(40, 87, 107, 0.08));
    }

    .crab-mark {
      right: 3.2rem;
      top: 21rem;
      width: 110px;
      height: 110px;
      opacity: 0.78;
      filter: drop-shadow(0 5px 8px rgba(109, 74, 56, 0.08));
    }

    .content {
      position: relative;
      z-index: 1;
    }

    header {
      position: relative;
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 1.5rem;
      align-items: start;
      margin-bottom: 1.4rem;
      padding-bottom: 1.4rem;
      border-bottom: 1px solid rgba(109, 74, 56, 0.18);
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 0.55rem;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      background: rgba(244, 201, 107, 0.25);
      color: var(--coffee);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-weight: 700;
    }

    header h1 {
      margin: 0;
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      color: var(--deep-sea);
    }

    .lede {
      margin: 0.7rem 0 0;
      max-width: 34rem;
      font-size: 1.06rem;
      line-height: 1.7;
      color: #415058;
    }

    .stamp-stack {
      display: grid;
      gap: 0.85rem;
      justify-items: end;
    }

    .stamp-card,
    .coffee-card {
      width: min(100%, 250px);
      padding: 1rem;
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,248,238,0.88));
      border: 1px solid rgba(216, 121, 89, 0.22);
      box-shadow: 0 10px 24px rgba(0,0,0,0.06);
      transform: rotate(1.5deg);
    }

    .coffee-card {
      transform: rotate(-2deg);
      border-color: rgba(109, 74, 56, 0.18);

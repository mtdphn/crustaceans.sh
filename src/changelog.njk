<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | crustaceans.sh</title>
  <style>
    :root {
      --sand: #f6efe2;
      --cream: #fffaf1;
      --foam: #f5fbff;
      --sea: #5d8fa3;
      --deep-sea: #28576b;
      --coral: #d87959;
      --ink: #26343c;
      --coffee: #6d4a38;
      --sun: #f4c96b;
      --shadow: rgba(37, 53, 66, 0.16);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --sand: #1a1f24;
        --cream: #232a30;
        --foam: #2d353d;
        --sea: #5d8fa3;
        --deep-sea: #8ab4c7;
        --coral: #d87959;
        --ink: #e8ebe8;
        --coffee: #b8a595;
        --sun: #f4c96b;
        --shadow: rgba(0, 0, 0, 0.4);
      }
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(244, 201, 107, 0.12), transparent 24%),
        radial-gradient(circle at top right, rgba(93, 143, 163, 0.1), transparent 30%),
        linear-gradient(180deg, var(--sand) 0%, #2a3038 42%, #1f242a 100%);
      transition: background 0.3s ease;
    }

    .frame {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(255,255,255,0.4));
      border-radius: 28px;
      box-shadow: 0 24px 64px var(--shadow);
    }

    .sheet {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, var(--cream), #fff5e8);
      border: 2px solid #ead8b8;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: inset 0 0 0 10px rgba(255,255,255,0.34);
    }

    
    .theme-toggle {
      position: absolute;
      top: 2rem;
      right: 2rem;
      background: var(--cream);
      border: 1px solid rgba(109, 74, 56, 0.2);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s ease, background 0.3s ease;
      z-index: 10;
    }
    .theme-toggle:hover { transform: scale(1.1); }

.coffee-ring {
      position: absolute;
      right: 2.8rem;
      top: 1.2rem;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      border: 6px solid rgba(109, 74, 56, 0.22);
      box-shadow: inset 0 0 0 12px rgba(109, 74, 56, 0.05);
      transform: rotate(-10deg);
      opacity: 0.55;
      mix-blend-mode: multiply;
      pointer-events: none;
    }
